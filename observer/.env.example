# API Connection
API_BASE_URL=http://localhost:4000       # docker: "http://api:4000"
API_WS_URL=ws://localhost:4000           # docker: "ws://api:4000"
INTERNAL_API_KEY=change-this-shared-secret

# Browser Configuration
CHROME_VERSION=131
HEADLESS=1
REBROWSER_PATCHES_RUNTIME_FIX_MODE=alwaysIsolated

# Browser profile persistence directory
BROWSER_PROFILES_DIR=./browser-profiles

# Observer identity
OBSERVER_ID=observer-1
