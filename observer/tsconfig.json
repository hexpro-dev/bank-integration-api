{
	"include": ["src/**/*"],
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"rootDir": "./src",
		"moduleResolution": "nodenext",
		"baseUrl": ".",
		"paths": {
			"#*": ["src/*"]
		},
		"typeRoots": ["./node_modules/@types", "./src/types"],
		"declaration": true,
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true
	}
}
