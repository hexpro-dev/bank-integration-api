# PostgreSQL
POSTGRES_USER=bankapi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bankapi
POSTGRES_PORT=5432                      # Host port for Postgres (optional, default: 5432)
DATABASE_URL=postgres://bankapi:changeme@postgres:5432/bankapi  # docker
# DATABASE_URL=postgres://bankapi:changeme@localhost:5432/bankapi  # local

# Secrets (used by API infra-config.json)
# JWT_SECRET=change-this-to-a-random-secret
# ENCRYPTION_KEY=change-this-32-byte-hex-key
# INTERNAL_API_KEY=change-this-shared-secret

# Public-facing API URL (used to generate webhook URLs for SMS providers like Twilio)
# In production, set this to your externally reachable API URL (e.g. https://api.yourdomain.com)
API_PUBLIC_URL=http://localhost:4000
API_PORT=4000                           # Host port for the API (optional, default: 4000)

# Observer
API_BASE_URL=http://api:4000       # docker: "http://api:4000", local: "http://localhost:4000"
API_WS_URL=ws://api:4000           # docker: "ws://api:4000", local: "ws://localhost:4000"
CHROME_VERSION=131
HEADLESS=1
REBROWSER_PATCHES_RUNTIME_FIX_MODE=alwaysIsolated

# Frontend
VITE_API_URL=http://localhost:4000  # Accessed from browser, always use external URL
FRONTEND_PORT=3000                  # Host port for the frontend (optional, default: 3000)

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
